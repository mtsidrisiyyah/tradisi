rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: is user authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: does the requesting user's profile document exist
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Helper: get requesting user's roles array
    function getUserRoles() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }
    
    // Helper: check if requesting user has a specific role
    function hasRole(role) {
      return isAuthenticated() && userDocExists() && role in getUserRoles();
    }
    
    // Helper: is requesting user an admin
    function isAdmin() {
      return hasRole('super_admin') || hasRole('admin_madrasah');
    }

    // User profiles: users/{uid}
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || request.auth.uid == uid;
      allow delete: if isAdmin();
    }
    
    // Collections: collections/{collectionName}
    match /collections/{collectionName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
