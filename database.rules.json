    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('roles').exists() && (root.child('users').child(auth.uid).child('roles').hasChild('super_admin') || root.child('users').child(auth.uid).child('roles').hasChild('admin_madrasah')))",
        ".validate": "newData.hasChildren(['email', 'roles', 'status'])",
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'aktif' || newData.val() === 'menunggu_persetujuan' || newData.val() === 'nonaktif')"
        },
        "roles": {
          ".validate": "newData.isArray()"
        }
      }
    },

